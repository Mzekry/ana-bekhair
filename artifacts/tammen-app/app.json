{
  "expo": {
    "name": "Ana Bekhair",
    "locales": {
      "ar": "./locales/ar.json"
    },
    "slug": "tammen-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "tammen-app",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#2d9e7e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lifekit.im-ok",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSForceRightToLeftWritingDirection": true,
        "ExpoLocalization_forcesRTL": true
      },
      "buildNumber": "3"
    },
    "android": {
      "package": "com.lifekit.im_ok",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-contacts",
      "@react-native-firebase/app",
      [
        "expo-build-properties",
        {}
      ],
      "expo-localization",
      "./withModularHeaders.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "f60c1b66-fa57-48ee-b6d0-2e1566207272"
      },
      "router": {
        "origin": "https://replit.com/"
      }
    }
  }
}
